  "targets": {
    "author": {
      "selectors": [
        "meta[name=\"author\"]",
        "[rel=\"author\"]",
        "[itemprop=\"author\"]",
        ".author",
        ".byline",
        ".post-author",
        "[class*=\"author-name\"]"
      ]
    },
    "publishDate": {
      "selectors": [
        "time[datetime]",
        "meta[property=\"article:published_time\"]",
